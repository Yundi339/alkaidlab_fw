# alkaidlab_fw-config.cmake
# 自动生成 — 消费方 find_package(alkaidlab_fw) 时加载
# 提供 IMPORTED 目标 alkaidlab_fw 及其全部传递依赖

get_filename_component(ALKAIDLAB_FW_INSTALL_PREFIX "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

# ---- IMPORTED 目标 ----
if(NOT TARGET alkaidlab_fw)
    add_library(alkaidlab_fw STATIC IMPORTED)
    set_target_properties(alkaidlab_fw PROPERTIES
        IMPORTED_LOCATION "${ALKAIDLAB_FW_INSTALL_PREFIX}/lib/libalkaidlab_fw.a"
        INTERFACE_INCLUDE_DIRECTORIES "${ALKAIDLAB_FW_INSTALL_PREFIX}/include"
    )
    # Windows: 把构建时设置的 PUBLIC compile defs / options 也传给消费方。
    # 这些设置阻止 windows.h 注入 min/max/ERROR 等宏，并补齐 POSIX 兼容垫片。
    if(WIN32)
        set_property(TARGET alkaidlab_fw APPEND PROPERTY
            INTERFACE_COMPILE_DEFINITIONS
                NOMINMAX
                WIN32_LEAN_AND_MEAN
                NOGDI
        )
        set_property(TARGET alkaidlab_fw APPEND PROPERTY
            INTERFACE_COMPILE_OPTIONS
                "-include" "fw/WinPosixShim.hpp"
        )
    endif()
endif()

# ---- 传递依赖 ----
# Boost
find_package(Boost QUIET COMPONENTS thread chrono system filesystem random)

# OpenSSL
set(_FW_OPENSSL_FOUND @_FW_OPENSSL_FOUND@)
if(_FW_OPENSSL_FOUND)
    find_package(OpenSSL QUIET)
endif()

# Threads
find_package(Threads QUIET)

# libhv（fw 内部使用）
set(_FW_LIBHV_LIB "@_FW_LIBHV_LIB_PATH@")
set(_FW_LIBHV_INCLUDE "@_FW_LIBHV_INCLUDE@")
if(NOT TARGET _fw_libhv)
    if(EXISTS "${_FW_LIBHV_LIB}")
        add_library(_fw_libhv STATIC IMPORTED)
        set_target_properties(_fw_libhv PROPERTIES
            IMPORTED_LOCATION "${_FW_LIBHV_LIB}"
        )
        if(IS_DIRECTORY "${_FW_LIBHV_INCLUDE}")
            set_property(TARGET _fw_libhv PROPERTY
                INTERFACE_INCLUDE_DIRECTORIES "${_FW_LIBHV_INCLUDE}")
        endif()
        # libhv 依赖 OpenSSL
        set(_FW_LIBHV_DEPS "")
        if(OPENSSL_FOUND)
            list(APPEND _FW_LIBHV_DEPS OpenSSL::SSL OpenSSL::Crypto)
        endif()
        # io_uring（如有）
        set(_FW_HAS_IO_URING @_FW_HAS_IO_URING@)
        if(_FW_HAS_IO_URING)
            find_library(_FW_URING_LIB uring)
            if(_FW_URING_LIB)
                list(APPEND _FW_LIBHV_DEPS ${_FW_URING_LIB})
            endif()
        endif()
        # Windows: libhv 使用 Winsock2 / iphlpapi，必须传递给所有链接方
        if(WIN32)
            list(APPEND _FW_LIBHV_DEPS ws2_32 iphlpapi)
        endif()
        if(_FW_LIBHV_DEPS)
            set_property(TARGET _fw_libhv PROPERTY INTERFACE_LINK_LIBRARIES ${_FW_LIBHV_DEPS})
        endif()
    endif()
endif()

# 组装 alkaidlab_fw INTERFACE_LINK_LIBRARIES
set(_FW_ALL_DEPS "")
if(TARGET _fw_libhv)
    list(APPEND _FW_ALL_DEPS _fw_libhv)
endif()
if(Boost_FOUND)
    list(APPEND _FW_ALL_DEPS
        Boost::thread Boost::chrono Boost::system Boost::filesystem Boost::random)
endif()
if(TARGET Threads::Threads)
    list(APPEND _FW_ALL_DEPS Threads::Threads)
endif()
set_property(TARGET alkaidlab_fw PROPERTY INTERFACE_LINK_LIBRARIES ${_FW_ALL_DEPS})

set(alkaidlab_fw_FOUND TRUE)
